{
  "name": "croo-cap-auditor",
  "version": "0.1.0",
  "description": "CAP Sentinel is a paid, callable CROO agent that audits CAP hackathon submissions for integration readiness, listing quality, and verifiable delivery.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cap-sentinel": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts audit --input examples/sample-submission.json --format markdown",
    "demo:json": "tsx src/cli.ts audit --input examples/sample-submission.json --format json",
    "demo:logo": "node scripts/make-logo.mjs",
    "demo:video": "node scripts/make-demo-video.mjs",
    "provider": "tsx src/provider.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "tsx src/run-tests.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "croo",
    "cap",
    "ai-agent",
    "a2a",
    "hackathon",
    "verification"
  ],
  "author": "CAP Sentinel Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/node": "^26.0.1",
    "canvas": "^3.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
